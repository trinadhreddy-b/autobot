# ============================================================
# Multi-Tenant AI Chatbot Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys.
# The system uses a fallback chain: Gemini → Groq → DeepSeek → OpenRouter
# You only need AT LEAST ONE key for the system to work.
# ============================================================

# ── Primary: Google Gemini 2.0 Flash (FREE tier) ─────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Fallback 1: Groq — Llama 3.3 70B (FREE tier) ────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Fallback 2: DeepSeek V3 ──────────────────────────────────
# Get your key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Fallback 3: OpenRouter — Qwen 2.5 72B (FREE model) ──────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Embedding model (optional override) ──────────────────────
# Options: "BAAI/bge-small-en-v1.5" or "sentence-transformers/all-MiniLM-L6-v2"
EMBED_MODEL=BAAI/bge-small-en-v1.5

# ── Google OAuth (optional — enables "Sign in with Google") ──
# Create credentials at: https://console.cloud.google.com/apis/credentials
# App type: Web application
# Authorized redirect URI: http://localhost:8000/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback

# ── App settings ─────────────────────────────────────────────
PYTHONUNBUFFERED=1
